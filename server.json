{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.evocrawl/evocrawl-mcp-server",
  "title": "Evocrawl MCP Server",
  "description": "MCP server for Evocrawl — search, scrape, and interact with the web.",
  "version": "3.7.4",
  "repository": {
    "url": "https://github.com/evocrawl/evocrawl-mcp-server.git",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "evocrawl-mcp",
      "version": "3.7.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for Evocrawl",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "EVOCRAWL_API_KEY"
        }
      ]
    }
  ]
}

